{
    "name": "nexium-test",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "packageManager": "pnpm@10.30.3",
    "scripts": {
        "generate:bindings": "cargo test export_bindings --manifest-path ../Cargo.toml",
        "dev": "vite dev",
        "preview": "vite preview",
        "build": "run-p type-check build-only",
        "prepare": "svelte-kit sync || echo ''",
        "build-only": "vite build",
        "type-check": "svelte-check",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "test:e2e": "playwright test",
        "tauri": "tauri",
        "clean": "run-p clean:svelte clean:tauri",
        "clean:svelte": "rimraf dist",
        "clean:tauri": "cargo clean --manifest-path src-tauri/Cargo.toml"
    },
    "dependencies": {
        "@darco2903/web-common": "^0.6.4",
        "@number-flow/svelte": "^0.3.13",
        "@tauri-apps/api": "~2.10.1",
        "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
        "@tauri-apps/plugin-dialog": "~2.2.2",
        "@tauri-apps/plugin-fs": "~2.2.1",
        "@tauri-apps/plugin-notification": "~2.2.3",
        "flowbite-svelte": "^1.31.0",
        "lucide-svelte": "^0.501.0",
        "neverthrow": "^8.2.0"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.1",
        "@eslint/js": "^9.39.3",
        "@iconify/json": "^2.2.445",
        "@playwright/test": "^1.58.2",
        "@sveltejs/adapter-auto": "^4.0.0",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.53.4",
        "@sveltejs/vite-plugin-svelte": "^5.1.1",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.1",
        "@tauri-apps/cli": "^2.10.0",
        "@types/node": "^25.3.3",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.15.0",
        "globals": "^16.5.0",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.0",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "rimraf": "^6.1.3",
        "svelte": "^5.53.6",
        "svelte-check": "^4.4.4",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "unplugin-icons": "^22.5.0",
        "vite": "^6.4.1"
    }
