{
    "name": "nexium-test",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "packageManager": "pnpm@10.30.3",
    "scripts": {
        "generate:bindings": "cargo test export_bindings --manifest-path src-tauri/Cargo.toml",
        "dev": "vite dev",
        "preview": "vite preview",
        "build": "run-p type-check build-only",
        "prepare": "svelte-kit sync || echo ''",
        "build-only": "vite build",
        "type-check": "svelte-check",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "test:e2e": "playwright test",
        "tauri": "tauri",
        "clean": "run-p clean:svelte clean:tauri",
        "clean:svelte": "rimraf dist",
        "clean:tauri": "cargo clean --manifest-path src-tauri/Cargo.toml"
    },
    "dependencies": {
        "@darco2903/web-common": "^0.6.4",
        "@number-flow/svelte": "^0.3.7",
        "@tauri-apps/api": "~2.5.0",
        "@tauri-apps/plugin-clipboard-manager": "~2.2.0",
        "@tauri-apps/plugin-dialog": "~2.2.0",
        "@tauri-apps/plugin-fs": "~2.2.0",
        "@tauri-apps/plugin-notification": "~2.2.0",
        "flowbite-svelte": "^1.4.3",
        "lucide-svelte": "^0.501.0",
        "neverthrow": "^8.2.0"
    },
    "devDependencies": {
        "@eslint/compat": "^1.2.5",
        "@eslint/js": "^9.18.0",
        "@iconify/json": "^2.2.329",
        "@playwright/test": "^1.49.1",
        "@sveltejs/adapter-auto": "^4.0.0",
        "@sveltejs/adapter-static": "^3.0.8",
        "@sveltejs/kit": "^2.16.0",
        "@sveltejs/vite-plugin-svelte": "^5.0.0",
        "@tailwindcss/forms": "^0.5.9",
        "@tailwindcss/typography": "^0.5.15",
        "@tailwindcss/vite": "^4.1.4",
        "@tauri-apps/cli": "^2.5.0",
        "@types/node": "^25.3.3",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-svelte": "^3.0.0",
        "globals": "^16.0.0",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.4.2",
        "prettier-plugin-svelte": "^3.3.3",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "rimraf": "^6.1.3",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "tailwindcss": "^4.1.4",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.20.0",
